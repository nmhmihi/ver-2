rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Rules for the 'users' collection
    match /users/{userId} {
      // TEMPORARY DEBUGGING RULE: Allow any authenticated user to write.
      // This will be tightened again after diagnosis.
      allow read, write: if request.auth != null;
    }

    // Rules for user-specific subcollections
    match /users/{userId}/{collection}/{docId} {
      // Allow full access (read, write, delete) only to the owner of the data.
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
